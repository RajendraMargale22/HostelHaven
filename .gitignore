# ─────────────────────────────────────────────
#  HOSTEL HAVEN — ROOT .gitignore
# ─────────────────────────────────────────────

# ── Environment files ─────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Node modules ──────────────────────────────
node_modules/
**/node_modules/

# ── Build output ──────────────────────────────
dist/
build/
.vite/

# ── Logs ──────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ── OS files ──────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db

# ── Editor ────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Misc ──────────────────────────────────────
coverage/
.nyc_output/
*.tgz
*.zip